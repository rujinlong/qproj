#!/usr/bin/env bash
# qg -- query the qproj dependency graph
#
# Generated by qproj::proj_scan_graph(); do not edit by hand. Re-running
# proj_scan_graph() refreshes the graph but leaves this wrapper intact.
#
# Usage:  bash .qproj/graph/qg <subcommand> [args]
#         (or simply `.qproj/graph/qg <subcommand>` once chmod +x)
# Help:   bash .qproj/graph/qg --help
#
# Reads:  .qproj/graph/qproj-graph.json (override with $QPROJ_GRAPH_JSON)
# Needs:  jq (>= 1.6); `qg stale` additionally needs git.

set -eu

# ---- locate the JSON ------------------------------------------------------
# Resolve script dir in a way that works on both BSD (macOS) and GNU.
SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"; done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
JSON="${QPROJ_GRAPH_JSON:-$SCRIPT_DIR/qproj-graph.json}"

if ! command -v jq >/dev/null 2>&1; then
  echo "qg: 'jq' is required but not installed." >&2
  echo "    macOS:  brew install jq" >&2
  echo "    Debian: apt install jq" >&2
  echo "    Other:  https://stedolan.github.io/jq/download/" >&2
  exit 127
fi

if [ ! -f "$JSON" ]; then
  echo "qg: graph not found at $JSON" >&2
  echo "    Run \`Rscript -e 'qproj::proj_scan_graph()'\` from the project root." >&2
  exit 2
fi

# ---- usage ----------------------------------------------------------------
usage() {
  cat <<EOF
qg -- query the qproj dependency graph (statically scanned by proj_scan_graph()).

Usage:
  qg <subcommand> [args] [--human|--json]

Discovery:
  qg list [step|function|table]   List node ids of a kind (or all).
  qg node <id>                    Node metadata + direct neighbours.

Tracing (use before any structural change):
  qg upstream <id>                Direct incoming edges (who feeds <id>).
  qg downstream <id>              Direct outgoing edges (who consumes <id>).
  qg deps <id>                    Transitive upstream closure.
  qg impact <id>                  Transitive downstream closure -- the blast
                                  radius of changing or removing <id>.
  qg paths <a> <b> [--max N]      All dependency paths from <a> to <b>
                                  (default max depth 6).

Cleanup helpers (use before submission / archiving):
  qg unused                       Functions defined but never called +
                                  tables written but never read.
  qg bypass                       bypass_access edges (anti-pattern).
  qg stale [--days N]             Steps with zero downstream consumers AND no
                                  git commit in N days (default 90).

Output formats:
  default       One fact per line, machine-friendly (greppable, pipe-able).
  --human       Compact human-friendly format.
  --json        Raw JSON (for piping into other tools).

Examples:
  qg impact 010-import_virome     # what breaks if I touch this step?
  qg unused                       # what can I delete?
  qg stale --days 60              # what hasnt been touched in 2 months?
  qg paths 010-import 050-mae     # how does data flow A -> B?

Graph file: $JSON
Override:   QPROJ_GRAPH_JSON env var
EOF
}

# ---- arg parse ------------------------------------------------------------
[ $# -eq 0 ] && { usage; exit 0; }
case "$1" in
  -h|--help|help)    usage; exit 0 ;;
  version|--version) jq -r '.metadata.qproj_version // "unknown"' "$JSON"; exit 0 ;;
esac

CMD="$1"; shift
FORMAT="text"
ARGS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --human) FORMAT="human"; shift ;;
    --json)  FORMAT="json";  shift ;;
    *)       ARGS+=("$1");   shift ;;
  esac
done

# ---- helpers --------------------------------------------------------------
need_id() {
  if [ "${#ARGS[@]}" -lt 1 ]; then
    echo "qg $CMD: missing <id> argument" >&2
    exit 1
  fi
  local exists
  exists=$(jq --arg id "${ARGS[0]}" '[.nodes[] | select(.id == $id)] | length' "$JSON")
  if [ "$exists" -eq 0 ]; then
    echo "qg $CMD: node not found: ${ARGS[0]}" >&2
    echo "Hint: run \`qg list\` to see all node ids." >&2
    exit 1
  fi
}

# ---- subcommands ----------------------------------------------------------
cmd_list() {
  local kind="${ARGS[0]:-}"
  if [ -n "$kind" ]; then
    jq --arg t "$kind" -r '.nodes[] | select(.type == $t) | .id' "$JSON"
  else
    jq -r '.nodes[] | "\(.type)\t\(.id)"' "$JSON"
  fi
}

cmd_node() {
  need_id
  local id="${ARGS[0]}"
  if [ "$FORMAT" = "json" ]; then
    jq --arg id "$id" '.nodes[] | select(.id == $id)' "$JSON"
    return
  fi
  if [ "$FORMAT" = "human" ]; then
    jq --arg id "$id" -r '
      .nodes[] | select(.id == $id) |
      "Node:    \(.id)
Type:    \(.type)
File:    \(.file // "?")
Order:   \(.render_order // "?")
Fan in:  \(.fan_in // 0)
Fan out: \(.fan_out // 0)"' "$JSON"
  else
    jq --arg id "$id" -r '
      .nodes[] | select(.id == $id) |
      "id\t\(.id)
type\t\(.type)
file\t\(.file // "")
render_order\t\(.render_order // "")
fan_in\t\(.fan_in // 0)
fan_out\t\(.fan_out // 0)"' "$JSON"
  fi
  echo "--"
  echo "incoming:"
  jq --arg id "$id" -r '.edges[] | select(.target == $id) | "  \(.source)\t\(.type)\t\(.confidence)"' "$JSON"
  echo "outgoing:"
  jq --arg id "$id" -r '.edges[] | select(.source == $id) | "  \(.target)\t\(.type)\t\(.confidence)"' "$JSON"
}

cmd_upstream() {
  need_id
  jq --arg id "${ARGS[0]}" -r \
    '.edges[] | select(.target == $id) | "\(.source)\t\(.type)\t\(.confidence)"' "$JSON"
}

cmd_downstream() {
  need_id
  jq --arg id "${ARGS[0]}" -r \
    '.edges[] | select(.source == $id) | "\(.target)\t\(.type)\t\(.confidence)"' "$JSON"
}

# Iterative BFS over an in-memory edge TSV.
#   direction = forward  -> impact (blast radius)  -- from upstream to downstream
#   direction = reverse  -> deps   (ancestry)      -- from downstream to upstream
#
# We first normalise every relevant edge to (from = upstream, to = downstream).
# Most edges already use that convention, but uses_function is drawn caller -> callee
# even though semantically the callee is the *upstream* dependency (changing
# the callee impacts the caller). So we flip uses_function before BFS.
# render_order is an ordering hint, not a data dependency, and is excluded.
cmd_closure() {
  local direction="$1"; shift
  need_id
  local id="${ARGS[0]}"

  local edges_tsv
  edges_tsv=$(jq -r '
    .edges[]
    | if .type == "uses_function" then {from: .target, to: .source}
      elif .type == "reads_from" or .type == "bypass_access"
           or .type == "writes_table" or .type == "reads_table"
           then {from: .source, to: .target}
      else empty end
    | "\(.from)\t\(.to)"
  ' "$JSON")

  local frontier="$id"
  local seen="$id"
  local depth=0
  local results=""
  while [ -n "$frontier" ]; do
    depth=$((depth + 1))
    local next=""
    while IFS= read -r seed; do
      [ -z "$seed" ] && continue
      local cands
      if [ "$direction" = "forward" ]; then
        cands=$(printf '%s\n' "$edges_tsv" | awk -F'\t' -v s="$seed" '$1 == s {print $2}')
      else
        cands=$(printf '%s\n' "$edges_tsv" | awk -F'\t' -v s="$seed" '$2 == s {print $1}')
      fi
      while IFS= read -r c; do
        [ -z "$c" ] && continue
        if ! printf '%s\n' "$seen" | grep -Fxq "$c"; then
          seen=$(printf '%s\n%s' "$seen" "$c")
          next=$(printf '%s\n%s' "$next" "$c")
          results=$(printf '%s\n%s\t%d' "$results" "$c" "$depth")
        fi
      done <<<"$cands"
    done <<<"$frontier"
    frontier=$(printf '%s\n' "$next" | sed '/^$/d')
    [ "$depth" -gt 50 ] && break
  done
  printf '%s\n' "$results" | sed '/^$/d'
}

cmd_impact() { cmd_closure forward "$@"; }
cmd_deps()   { cmd_closure reverse "$@"; }

cmd_unused() {
  # The graph JSON is written with auto_unbox=TRUE, so single-element string
  # arrays land as bare strings. Normalise via tostring + split, which is
  # type-stable for both shapes.
  jq -r '
    def aslist(x): if (x | type) == "array" then x
                   elif x == null then []
                   else [x] end;
    .nodes[] | select(.type == "function" and (.unused == true)) |
    "function\t\(.id)\t\(.file // "?"):\(.line // "?")"
  ' "$JSON"
  jq -r '
    def aslist(x): if (x | type) == "array" then x
                   elif x == null then []
                   else [x] end;
    .nodes[] | select(.type == "table"
                      and (aslist(.readers) | length) == 0
                      and (aslist(.writers) | length) >  0) |
    "orphan_table\t\(.id)\twriters: \(aslist(.writers) | join(","))"
  ' "$JSON"
}

cmd_bypass() {
  jq -r '
    .edges[] | select(.type == "bypass_access") |
    "\(.source)\t->\t\(.target)\t\(.evidence.file // "?"):\(.evidence.line // "?")"
  ' "$JSON"
}

cmd_stale() {
  local days=90
  local i=0
  while [ $i -lt ${#ARGS[@]} ]; do
    case "${ARGS[$i]}" in
      --days)
        i=$((i + 1))
        days="${ARGS[$i]:-90}"
        ;;
    esac
    i=$((i + 1))
  done

  if ! command -v git >/dev/null 2>&1; then
    echo "qg stale: requires git" >&2; exit 127
  fi

  local now
  now=$(date +%s)
  jq -r '.nodes[] | select(.type == "step" and (.fan_out // 0) == 0) | "\(.id)\t\(.file // "")"' "$JSON" |
  while IFS=$'\t' read -r id file; do
    [ -z "$file" ] && continue
    local last
    last=$(git log -1 --format=%ct -- "$file" 2>/dev/null || true)
    [ -z "$last" ] && continue
    local age_days=$(( (now - last) / 86400 ))
    if [ "$age_days" -ge "$days" ]; then
      printf '%s\tlast_modified_days_ago=%d\tfile=%s\n' "$id" "$age_days" "$file"
    fi
  done
}

cmd_paths() {
  if [ "${#ARGS[@]}" -lt 2 ]; then
    echo "qg paths: usage: qg paths <a> <b> [--max N]" >&2
    exit 1
  fi
  local a="${ARGS[0]}" b="${ARGS[1]}"
  local max=6
  if [ "${#ARGS[@]}" -ge 4 ] && [ "${ARGS[2]}" = "--max" ]; then
    max="${ARGS[3]}"
  fi

  local edges_tsv
  edges_tsv=$(jq -r '
    .edges[]
    | if .type == "uses_function" then {from: .target, to: .source}
      elif .type == "reads_from" or .type == "bypass_access"
           or .type == "writes_table" or .type == "reads_table"
           then {from: .source, to: .target}
      else empty end
    | "\(.from)\t\(.to)"
  ' "$JSON")

  dfs() {
    local current="$1" target="$2" depth="$3" path="$4"
    if [ "$current" = "$target" ]; then
      echo "$path"
      return
    fi
    [ "$depth" -ge "$max" ] && return
    while IFS= read -r succ; do
      [ -z "$succ" ] && continue
      case " $path " in
        *" $succ "*) continue ;;
      esac
      dfs "$succ" "$target" $((depth + 1)) "$path $succ"
    done < <(printf '%s\n' "$edges_tsv" | awk -F'\t' -v s="$current" '$1 == s {print $2}')
  }
  dfs "$a" "$b" 0 "$a"
}

# ---- dispatch -------------------------------------------------------------
case "$CMD" in
  list)        cmd_list ;;
  node)        cmd_node ;;
  upstream)    cmd_upstream ;;
  downstream)  cmd_downstream ;;
  impact)      cmd_impact ;;
  deps)        cmd_deps ;;
  unused)      cmd_unused ;;
  bypass)      cmd_bypass ;;
  stale)       cmd_stale ;;
  paths)       cmd_paths ;;
  *)
    echo "qg: unknown subcommand '$CMD'. Run \`qg --help\`." >&2
    exit 1
    ;;
esac
